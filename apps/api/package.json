{
  "name": "@qvix/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/db/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qvix/shared": "workspace:*",
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.16.1",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "redis": "^4.6.14",
    "socket.io": "^4.7.5",
    "dotenv": "^16.4.5",
    "uuid": "^10.0.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.16.1",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  }
}
